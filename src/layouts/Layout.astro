---
import "@/styles/main.css";
import { ClientRouter } from 'astro:transitions';
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import CommandPalette from "@/components/CommandPalette.astro";
import PostHog from "@/components/posthog.astro";

interface Props {
	title?: string;
	description?: string;
	jsonLd?: Record<string, any> | Record<string, any>[];
}

const { 
	title = "apiguide.dev | API Reference & Design Patterns", 
	description = "The flagship reference site for modern, authoritative API design patterns, Problem+JSON error schemas, and integration guides.",
	jsonLd
} = Astro.props;

// Compile a stable canonical URL
const canonicalURL = new URL(Astro.url.pathname, Astro.site || "https://apiguide.dev");

// Compile the Open Graph PNG preview image path dynamically
let ogImagePath = "index.png";
const pathParts = Astro.url.pathname.replace(/^\/|\/$/g, ""); // strip leading/trailing slashes
if (pathParts) {
	ogImagePath = `${pathParts}.png`;
}
const ogImageURL = new URL(`/og/${ogImagePath}`, Astro.site || "https://apiguide.dev");

// Resolve JSON-LD array inputs into single @graph schema arrays
const jsonLdPayload = Array.isArray(jsonLd)
  ? { 
      "@context": "https://schema.org", 
      "@graph": jsonLd.map(item => {
        const { "@context": _, ...rest } = item;
        return rest;
      }) 
    }
  : jsonLd;
---

<!doctype html>
<html lang="en" class="h-full bg-paper-50 text-paper-900 scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" href="/favicon-32x32.png" sizes="32x32" />
		<link rel="icon" type="image/png" href="/favicon-192x192.png" sizes="192x192" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/manifest.json" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;600&family=Inter:wght@300;400;500;600;700&family=Lora:ital,wght@0,400..700;1,400..700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
		
		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL.href} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL.href} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageURL.href} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL.href} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={ogImageURL.href} />

		<!-- JSON-LD Structured Data Injection -->
		{jsonLdPayload && (
			<script type="application/ld+json" set:html={JSON.stringify(jsonLdPayload)} />
		)}

		<!-- View Transitions -->
		<ClientRouter />

		<!-- PostHog Analytics -->
		<PostHog />
	</head>
	<body class="flex flex-col min-h-screen bg-paper-50 text-paper-900 selection:bg-chartres-200 selection:text-chartres-950 font-sans antialiased">
		<a href="#main-content" class="sr-only">Skip to main content</a>
		<!-- Persistent Sticky Header -->
		<Header />

		<!-- Main Content Slot -->
		<div id="main-content" class="grow">
			<slot />
		</div>

		<!-- Persistent Footer -->
		<Footer />

		<!-- Command Palette Search Overlay -->
		<CommandPalette />


	</body>
</html>
